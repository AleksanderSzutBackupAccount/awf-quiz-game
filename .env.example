# ---- Frontend (Nuxt) — wymagane ----
# Lokalnie: wartości z `supabase start`. Produkcja: z dashboardu projektu Supabase.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=<anon key>           # klucz "anon" (publiczny)
SITE_URL=http://localhost:3000

# ---- Google OAuth (opcjonalne lokalnie, wymagane do logowania Google) ----
# Utwórz OAuth Client (Web) w Google Cloud Console, dodaj redirect:
#   http://127.0.0.1:54321/auth/v1/callback   (lokalnie)
#   https://<PROJECT_REF>.supabase.co/auth/v1/callback   (produkcja)
# Następnie w supabase/config.toml ustaw [auth.external.google] enabled = true
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# ---- CI/CD (ustaw jako GitHub Secrets, nie tutaj) ----
# SUPABASE_ACCESS_TOKEN   – z https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF    – ref produkcyjnego projektu (Project Settings → General)
# SUPABASE_DB_PASSWORD    – hasło bazy produkcyjnej
